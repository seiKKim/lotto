# Turso(libSQL) 접속 정보. 로컬 개발 시 비워두면 file:data/lotto.db 사용.
# Vercel 배포 시 두 값을 환경변수로 등록해야 한다.
#   turso db show <name> --url
#   turso db tokens create <name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# (선택) 로컬 개발 시 Ollama로 추천 멘트 자동 생성. 없으면 고정문구로 폴백.
# Vercel 등 서버리스 배포본에선 자동 비활성화된다.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma3:latest

# Kakao 로컬 검색 REST 키 (내 주변 판매점 탭). developers.kakao.com → 카카오맵 활성화.
# 없으면 '미배출 판매점' 탭은 비활성, '1등 배출점'만 동작.
KAKAO_REST_KEY=
